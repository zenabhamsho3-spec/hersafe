function getClosestArea(lat, lng) {
    let minDict = Infinity;
    let closest = "غير محدد";
    for (const [name, pos] of Object.entries(areaCenters)) {
        // Approximate distance calculation (Euclidean is fine for small scale comparison)
        const dist = Math.pow(lat - pos[0], 2) + Math.pow(lng - pos[1], 2);
        if (dist < minDict) { minDict = dist; closest = name; }
    }
    return closest;
}

let chart;
function updateChart(data) {
    const counts = {};
    data.forEach(a => {
        const area = getClosestArea(a.latitude, a.longitude);
        counts[area] = (counts[area] || 0) + 1;
    });

    const sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]).slice(0, 5);
    const labels = sorted.map(i => i[0]);
    const values = sorted.map(i => i[1]);

    const ctx = document.getElementById('dangerChart').getContext('2d');
    if (chart) chart.destroy();
    chart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'عدد البلاغات',
                data: values,
                backgroundColor: '#e91e63',
                borderRadius: 5
            }]
        },
        options: {
            indexAxis: 'y',
            plugins: { legend: { display: false } },
            scales: { x: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });
}

async function fetchData() {
    const response = await fetch('/api/data');
    if (response.status === 401) return;
    const data = await response.json();

    document.getElementById('todayCount').innerText = data.stats.today;

    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = '';

    // تنظيف الماركرز السابقة (اختياري، هنا سنضيف فقط الجديد)
    data.alerts.forEach(alert => {
        const row = \`<tr>
                    <td>\${alert.phone_number}</td>
                    <td>\${alert.latitude.toFixed(2)},\${alert.longitude.toFixed(2)}</td>
                    <td><a href="https://www.google.com/maps?q=\${alert.latitude},\${alert.longitude}" target="_blank" class="btn">تتبع</a></td>
                </tr>\`;
                tbody.innerHTML += row;

                L.marker([alert.latitude, alert.longitude])
                 .addTo(map)
                 .bindPopup(\`<b>خطر!</b><br>هاتف: \${alert.phone_number}<br>الوقت: \${new Date(alert.created_at).toLocaleTimeString('ar-SA')}\`);
            });

            updateChart(data.alerts);
        }

        fetchData();
        setInterval(fetchData, 15000); // تحديث كل 15 ثانية لمواكبة الخطر
    </script>
</body>
</html>`;
    }
